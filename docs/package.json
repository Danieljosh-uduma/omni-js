{
  "name": "docs",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "predev": "node -e \"require('fs').copyFileSync('../packages/runtime/dist/omni-runtime.js', './omni-runtime.js')\"",
    "dev": "concurrently \"tailwindcss -i ./src/input.css -o ./output.css --watch\" \"npx serve .\"",
    "build": "tailwindcss -i ./src/input.css -o ./output.css --minify && omni build src/App.omni --outdir=dist",
    "start": "npx serve dist"
  },
  "dependencies": {
    "@omni/cli": "*",
    "@omni/runtime": "*",
    "fuse.js": "^7.4.2",
    "gsap": "^3.15.0"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.1",
    "concurrently": "^10.0.3",
    "tailwindcss": "^4.3.1"
  }
}
