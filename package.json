{
  "name": "omni-js-monorepo",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "packages/*",
    "demo",
    "docs"
  ],
  "scripts": {
    "dev:example": "npm run dev --workspace=example",
    "build:cli": "npm run build --workspace=@omni/cli",
    "build:runtime": "npm run build --workspace=@omni/runtime",
    "build": "npm run build:runtime",
    "publish-all": "npm publish --workspace=packages/runtime --access public && npm publish --workspace=packages/cli --access public"
  }
}
